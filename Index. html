<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>My Portfolio</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

  <header>
    <h1>Janvi John</h1>
    <p>Web Developer | Student</p>
  </header>

  <nav>
    <a href="#about">About</a>
    <a href="#projects">Projects</a>
    <a href="#contact">Contact</a>
  </nav>

  <section id="about">
    <h2>About Me</h2>
    <p>I am a student passionate about web development and coding.</p>
  </section>

  <section id="projects">
    <h2>Projects</h2>
    <div class="card">
      <h3>Portfolio Website</h3>
      <p>A personal portfolio using HTML & CSS.</p>
    </div>
    <div class="card">
      <h3>Form Validation</h3>
      <p>Simple form validation using JavaScript.</p>
    </div>
  </section>

  <section id="contact">
    <h2>Contact Me</h2>
    <form onsubmit="return validateForm()">
      <input type="text" id="name" placeholder="Your Name"><br>
      <input type="email" id="email" placeholder="Your Email"><br>
      <textarea id="message" placeholder="Your Message"></textarea><br>
      <button type="submit">Send</button>
    </form>
    <p id="error"></p>
  </section>

  <footer>
    <p>© 2026 Janvi John</p>
  </footer>

  <script src="script.js"></script>
</body>
</html>
